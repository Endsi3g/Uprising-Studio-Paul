{
  "name": "actions-service",
  "version": "1.0.0",
  "description": "Paul's internal API service — pipeline, Ollama, and briefings",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "prisma:generate": "npx prisma generate --schema=../../db/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=../../db/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=../../db/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^7.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "prisma": "^6.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
